<Window x:Class="Puissance4.Interface.FenetreAccueil"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Puissance4.Interface"
        mc:Ignorable="d"
        Title="Puissance 4" Height="450" Width="800">
    <Grid Background="#FF0A111F">
        <Grid.RowDefinitions>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="4*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Bienvenue au Puissance 4 !" FontFamily="{StaticResource PlaypenSans}" FontSize="24" 
                   Foreground="White" Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center"/>

        <Button x:Name="BtnNewGame" Grid.Row="1" Content="Nouvelle Partie Classique" Height="60" Width="350" Background="#CBC7B7"
                Foreground="#FF0A111F" FontFamily="{StaticResource PlaypenSans}" FontSize="20" BorderThickness="0" 
                Click="BtnNewGame_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" 
                            CornerRadius="15" BorderBrush="White" BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
        <Button x:Name="BtnContinueGame" Grid.Row="2" Content="Reprendre une partie" Height="60" Width="350" Background="#CBC7B7"
                Foreground="#FF0A111F" FontFamily="{StaticResource PlaypenSans}" FontSize="20" BorderThickness="0" 
                Click="BtnContinueGame_Click" GotFocus="BtnContinueGame_GotFocus" LostFocus="BtnContinueGame_LostFocus">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" 
                            CornerRadius="15" BorderBrush="White" BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <Border x:Name="BorderNewGame" Grid.Row="2" Height="140" Width="400" Background="#1d1f23" CornerRadius="20" Visibility="Hidden">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition/>
                    <RowDefinition Height="2*"/>
                </Grid.RowDefinitions>

                <Button x:Name="BtnJouerA2" Grid.Row="0" Grid.Column="0" Content="Jouer à 2" Height="40" Width="150" Background="#cbc7b7"
                        Foreground="#FF0A111F" FontFamily="{StaticResource PlaypenSans}" FontSize="20" BorderThickness="0" 
                        Click="BtnJouerA2_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="10" BorderBrush="White" BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button x:Name="BtnJouerSeul" Grid.Row="0" Grid.Column="1" Content="Jouer seul" Height="40" Width="150" Background="#cbc7b7"
                        Foreground="#FF0A111F" FontFamily="{StaticResource PlaypenSans}" FontSize="20" BorderThickness="0" 
                        Click="BtnJouerSeul_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="10" BorderBrush="White" BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="Quel est le niveau de l'IA ?" FontFamily="{StaticResource PlaypenSans}" FontSize="20" 
                   Foreground="White" VerticalAlignment="Center" Margin="10,0,0,0"/>
                
                <Button x:Name="BtnIAIdiot" Grid.Row="2" Grid.Column="0" Content="Idiot" Height="40" Width="150" Background="#cbc7b7"
                        Foreground="#FF0A111F" FontFamily="{StaticResource PlaypenSans}" FontSize="20" BorderThickness="0"
                        Click="BtnIA_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="10" BorderBrush="White" BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button x:Name="BtnIAIntelligent" Grid.Row="2" Grid.Column="1" Content="Intelligent" Height="40" Width="150" Background="#cbc7b7"
                        Foreground="#FF0A111F" FontFamily="{StaticResource PlaypenSans}" FontSize="20" BorderThickness="0"
                        Click="BtnIA_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="10" BorderBrush="White" BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
