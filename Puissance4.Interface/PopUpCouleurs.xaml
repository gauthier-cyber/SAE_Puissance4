<Window x:Class="CouleursApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Couleurs" Height="300" Width="650"
        Background="#FF0A111F"
        FontFamily="{StaticResource PlaypenSans}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ========== PANNEAU DE GAUCHE ========== -->
        <StackPanel Grid.Column="0" Margin="15">
            <TextBlock Text="Couleurs" Foreground="White" FontSize="18"
                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <!-- Ligne 1 : rouge/jaune et blanc/noir -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,3">
                <Border Background="#D9C9A8" CornerRadius="20" Padding="8" Margin="4">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="30" Height="30" Fill="Red" Margin="4"/>
                        <Ellipse Width="30" Height="30" Fill="Yellow" Margin="4"/>
                    </StackPanel>
                </Border>
                <Border Background="#D9C9A8" CornerRadius="20" Padding="8" Margin="4">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="30" Height="30" Fill="White" Margin="4"/>
                        <Ellipse Width="30" Height="30" Fill="Black" Margin="4"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Ligne 2 : gris et bleu/violet -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,3">
                <Border Background="#D9C9A8" CornerRadius="20" Padding="8" Margin="4">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="30" Height="30" Fill="Gray" Margin="4"/>
                        <Ellipse Width="30" Height="30" Fill="DimGray" Margin="4"/>
                    </StackPanel>
                </Border>
                <Border Background="#D9C9A8" CornerRadius="20" Padding="8" Margin="4">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="30" Height="30" Fill="Blue" Margin="4"/>
                        <Ellipse Width="30" Height="30" Fill="Indigo" Margin="4"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Ligne 3 : verts et orange/vert -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,3">
                <Border Background="#D9C9A8" CornerRadius="20" Padding="8" Margin="4">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="30" Height="30" Fill="DarkOliveGreen" Margin="4"/>
                        <Ellipse Width="30" Height="30" Fill="#3B2A0A" Margin="4"/>
                    </StackPanel>
                </Border>
                <Border Background="#D9C9A8" CornerRadius="20" Padding="8" Margin="4">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="30" Height="30" Fill="Orange" Margin="4"/>
                        <Ellipse Width="30" Height="30" Fill="OliveDrab" Margin="4"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>

        <!-- ========== BARRE DE SÉPARATION ========== -->
        <Rectangle Grid.Column="1" Width="2" Fill="Black" VerticalAlignment="Stretch" Margin="0,10"/>

        <!-- ========== PANNEAU DE DROITE ========== -->
        <StackPanel Grid.Column="2" Margin="15">
            <TextBlock Text="Couleurs" Foreground="White" FontSize="18"
                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <!-- Ligne 1 : cercles et triangles -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,3">
                <Border Background="#D9C9A8" CornerRadius="20" Padding="8" Margin="4">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="30" Height="30" Fill="Red" Margin="4"/>
                        <Ellipse Width="30" Height="30" Fill="Yellow" Margin="4"/>
                    </StackPanel>
                </Border>
                <Border Background="#D9C9A8" CornerRadius="20" Padding="8" Margin="4">
                    <StackPanel Orientation="Horizontal">
                        <Polygon Points="15,0 30,30 0,30" Fill="Red" Margin="4"/>
                        <Polygon Points="15,0 30,30 0,30" Fill="Yellow" Margin="4"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Ligne 2 : étoiles 4 branches et étoiles 5 branches -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,3">
                <Border Background="#D9C9A8" CornerRadius="20" Padding="8" Margin="4">
                    <StackPanel Orientation="Horizontal">
                        <Polygon Points="15,0 19,11 30,15 19,19 15,30 11,19 0,15 11,11"
                                 Fill="Red" Margin="4"/>
                        <Polygon Points="15,0 19,11 30,15 19,19 15,30 11,19 0,15 11,11"
                                 Fill="Yellow" Margin="4"/>
                    </StackPanel>
                </Border>
                <Border Background="#D9C9A8" CornerRadius="20" Padding="8" Margin="4">
                    <StackPanel Orientation="Horizontal">
                        <Polygon Points="15,0 19,11 30,11 21,19 25,30 15,23 5,30 9,19 0,11 11,11"
                                 Fill="Red" Margin="4"/>
                        <Polygon Points="15,0 19,11 30,11 21,19 25,30 15,23 5,30 9,19 0,11 11,11"
                                 Fill="Yellow" Margin="4"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Ligne 3 : carrés arrondis et losanges -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,3">
                <Border Background="#D9C9A8" CornerRadius="20" Padding="8" Margin="4">
                    <StackPanel Orientation="Horizontal">
                        <Rectangle Width="30" Height="30" Fill="Red" RadiusX="6" RadiusY="6" Margin="4"/>
                        <Rectangle Width="30" Height="30" Fill="Yellow" RadiusX="6" RadiusY="6" Margin="4"/>
                    </StackPanel>
                </Border>
                <Border Background="#D9C9A8" CornerRadius="20" Padding="8" Margin="4">
                    <StackPanel Orientation="Horizontal">
                        <Polygon Points="15,0 30,15 15,30 0,15" Fill="Red" Margin="4"/>
                        <Polygon Points="15,0 30,15 15,30 0,15" Fill="Yellow" Margin="4"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
<!-- Pour le back-end, choisir un duo de couleurs, pas une seule dans un encadré et une seule dans un autre -->
